---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Naetharu.">
  <div class="page">
    <div class="container">
      <header class="page-header">
        <h1>Get in Touch</h1>
        <p>
          Whether you've spotted an error in a tutorial, have a question about something I've
          written, or just want to say hello — I'd love to hear from you.
        </p>
      </header>

      <div class="contact-grid">
        <!-- Contact form -->
        <div class="contact-form-wrap">
          <form class="contact-form" id="contact-form" novalidate>
            <div class="field">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your name" required />
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required />
            </div>
            <div class="field">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="What's it about?" />
            </div>
            <div class="field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="6" placeholder="Your message..." required></textarea>
            </div>
            <div id="form-status" class="form-status" aria-live="polite"></div>
            <button type="submit" class="btn submit-btn">Send message</button>
          </form>
        </div>

        <!-- Aside -->
        <aside class="contact-aside">
          <div class="aside-section">
            <h3>Response time</h3>
            <p>I try to reply within a few days. If your message is time-sensitive, mention that and I'll prioritise it.</p>
          </div>
          <div class="aside-section">
            <h3>Other ways to reach me</h3>
            <ul class="link-list">
              <li>
                <span class="link-label">GitHub</span>
                <a href="#" target="_blank" rel="noopener">github.com/naetharu</a>
              </li>
              <li>
                <span class="link-label">Twitter / X</span>
                <a href="#" target="_blank" rel="noopener">@naetharu</a>
              </li>
            </ul>
          </div>
          <div class="aside-section">
            <h3>What I'm open to</h3>
            <ul class="open-to-list">
              <li>Questions about tutorials or blog posts</li>
              <li>Corrections and errata</li>
              <li>Interesting project ideas or collaborations</li>
              <li>General chat about C++, graphics, or systems programming</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<!-- Client-side form handling (island of interactivity) -->
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLDivElement;
  const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name    = (form.elements.namedItem('name')    as HTMLInputElement).value.trim();
    const email   = (form.elements.namedItem('email')   as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) {
      showStatus('Please fill in all required fields.', 'error');
      return;
    }

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showStatus('Please enter a valid email address.', 'error');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    // Placeholder: replace with your actual form endpoint (e.g. Formspree, Netlify Forms)
    await new Promise(r => setTimeout(r, 800));

    showStatus('Thanks for your message! I\'ll get back to you soon.', 'success');
    form.reset();
    submitBtn.disabled = false;
    submitBtn.textContent = 'Send message';
  });

  function showStatus(msg: string, type: 'success' | 'error') {
    statusEl.textContent = msg;
    statusEl.className = `form-status form-status--${type}`;
  }
</script>

<style>
  .page { padding: 3rem 0 5rem; }

  .page-header {
    max-width: 560px;
    margin-bottom: 3rem;
  }

  .page-header h1 { margin-bottom: 0.75rem; }
  .page-header p { color: var(--color-text-muted); font-size: 1.05rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 800px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .field input,
  .field textarea {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.65rem 0.9rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    resize: vertical;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(124, 106, 247, 0.15);
  }

  .submit-btn { align-self: flex-start; }

  .form-status {
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    display: none;
  }

  .form-status:not(:empty) { display: block; }

  .form-status--success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #4ade80;
  }

  .form-status--error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #f87171;
  }

  /* Aside */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .aside-section h3 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
  }

  .aside-section p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .link-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .link-list li {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .link-label {
    color: var(--color-text-muted);
    min-width: 90px;
    font-size: 0.8rem;
  }

  .open-to-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0;
  }

  .open-to-list li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .open-to-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>
