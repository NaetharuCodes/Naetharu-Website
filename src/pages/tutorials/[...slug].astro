---
import { getCollection, render } from 'astro:content';
import ProseLayout from '../../layouts/ProseLayout.astro';

export async function getStaticPaths() {
  const collections = ['devops', 'microsoft-azure', 'scripts-and-automation', 'other'];
  const entriesArrays = await Promise.all(collections.map((c) => getCollection(c, ({ data }) => !data.draft)));
  const tutorials = entriesArrays.flat();
  return tutorials.map((tutorial) => ({
    params: { slug: tutorial.id },
    props: { tutorial },
  }));
}

const { tutorial } = Astro.props;
const { Content } = await render(tutorial);
---

<ProseLayout
  title={tutorial.data.title}
  description={tutorial.data.description}
  pubDate={tutorial.data.pubDate}
  tags={tutorial.data.tags}
  section="Tutorials"
  sectionHref="/tutorials"
  videoId={tutorial.data.videoId}
>
  <Content />
</ProseLayout>
