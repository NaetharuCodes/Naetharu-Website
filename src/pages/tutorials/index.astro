---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tutorials = [
  {
    slug: 'cpp-particle-systems',
    title: 'Particle Systems in C++',
    description: 'Build a data-oriented, cache-friendly particle system from scratch using modern C++ techniques. Covers SOA layout, emitters, update loops, and simple rendering.',
    tags: ['C++', 'Graphics', 'Systems'],
    date: '2025-03-10',
    available: true,
  },
  {
    slug: 'opengl-first-triangle',
    title: 'OpenGL Basics: Your First Triangle',
    description: 'Getting started with OpenGL — setting up a context with GLFW, writing your first vertex and fragment shaders, and drawing geometry to the screen.',
    tags: ['C++', 'OpenGL', 'Rendering'],
    date: null,
    available: false,
  },
  {
    slug: 'lock-free-queue',
    title: 'Writing a Lock-Free Queue in C++',
    description: 'Explore atomic operations and memory ordering to build a thread-safe, lock-free MPSC queue using std::atomic and careful reasoning about happens-before.',
    tags: ['C++', 'Concurrency', 'Data Structures'],
    date: null,
    available: false,
  },
];
---

<BaseLayout title="Tutorials" description="Step-by-step technical tutorials on C++, graphics programming, and systems topics.">
  <div class="page">
    <div class="container">
      <header class="page-header">
        <h1>Tutorials</h1>
        <p>
          In-depth, step-by-step guides on the topics I find most interesting. Mostly C++,
          systems programming, and graphics — written to be thorough rather than quick.
        </p>
      </header>

      <div class="tutorial-list">
        {tutorials.map(t => (
          <div class={`tutorial-item${t.available ? '' : ' tutorial-item--upcoming'}`}>
            <div class="tutorial-content">
              <div class="tutorial-tags">
                {t.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
              <h2 class="tutorial-title">
                {t.available
                  ? <a href={`/tutorials/${t.slug}`}>{t.title}</a>
                  : t.title
                }
              </h2>
              <p class="tutorial-desc">{t.description}</p>
            </div>
            <div class="tutorial-meta">
              {t.available && t.date
                ? <a href={`/tutorials/${t.slug}`} class="btn">Read tutorial &rarr;</a>
                : <span class="upcoming-label">Coming soon</span>
              }
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page { padding: 3rem 0 5rem; }

  .page-header {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .page-header h1 { margin-bottom: 0.75rem; }
  .page-header p { color: var(--color-text-muted); font-size: 1.05rem; }

  .tutorial-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .tutorial-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.75rem;
    background: var(--color-surface);
    transition: background 0.2s;
  }

  .tutorial-item:not(:last-child) { border-bottom: 1px solid var(--color-border); }
  .tutorial-item:hover { background: var(--color-surface-raised); }
  .tutorial-item--upcoming { opacity: 0.55; }

  .tutorial-content { flex: 1; }

  .tutorial-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .tutorial-title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .tutorial-title a {
    color: var(--color-text-heading);
    text-decoration: none;
  }

  .tutorial-title a:hover { color: var(--color-accent); }

  .tutorial-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .tutorial-meta { flex-shrink: 0; }

  .upcoming-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .tutorial-item { flex-direction: column; align-items: flex-start; }
  }
</style>
