---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const devops = await getCollection('devops', ({ data }: CollectionEntry) => !data.draft);
const azure = await getCollection('microsoft-azure', ({ data }: CollectionEntry) => !data.draft);
const scripts = await getCollection('scripts-and-automation', ({ data }: CollectionEntry) => !data.draft);
const other = await getCollection('other', ({ data }: CollectionEntry) => !data.draft);

const categories = ['DevOps', 'Microsoft Azure', 'Scripts and Automation', 'Other'];

const grouped: Record<string, CollectionEntry[]> = {
  'DevOps': devops,
  'Microsoft Azure': azure,
  'Scripts and Automation': scripts,
  'Other': other,
};

// Upcoming tutorials not yet written — add new entries here as placeholders
const upcoming: { title: string; description: string; tags: string[] }[] = [
  {
    title: 'OpenGL Basics: Your First Triangle',
    description: 'Getting started with OpenGL — setting up a context with GLFW, writing your first vertex and fragment shaders, and drawing geometry to the screen.',
    tags: ['C++', 'OpenGL', 'Rendering'],
  },
  {
    title: 'Writing a Lock-Free Queue in C++',
    description: 'Explore atomic operations and memory ordering to build a thread-safe, lock-free MPSC queue using std::atomic and careful reasoning about happens-before.',
    tags: ['C++', 'Concurrency', 'Data Structures'],
  },
];
---

<BaseLayout title="Tutorials" description="Step-by-step technical tutorials organized into topical sections.">
  <div class="page">
    <div class="container container--wide">
      <header class="page-header">
        <h1>Tutorials</h1>
        <p>
          Tutorials grouped into focused sections. Click a card to view tutorials in that
          section; within each section you can browse by tags.
        </p>
      </header>

      <div class="cards">
        {categories.map((cat: string) => (
          <a class="card" href={`/tutorials/${cat.toLowerCase().replace(/ /g, '-')}/`}>
            <div class="card-body">
              <h2 class="card-title">{cat}</h2>
              <p class="card-desc">{`Browse ${grouped[cat].length} tutorials in ${cat}.`}</p>
            </div>
            <div class="card-meta">View →</div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page { padding: 3rem 0 5rem; }
  .page-header { max-width: 720px; margin-bottom: 2.25rem; }

  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1rem; }

  .card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
    width: 100%;
    min-height: 84px;
  }
  .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }


  .card-body { flex: 1; min-width: 0; }
  .card-title { margin: 0 0 0.25rem 0; font-size: 1.05rem; }
  .card-desc { margin: 0; color: var(--color-text-muted); font-size: 0.95rem; }

  .card-meta { margin-left: 1rem; color: var(--color-accent); font-weight: 600; }

  @media (max-width: 800px) { .cards { grid-template-columns: 1fr; } }
</style>
