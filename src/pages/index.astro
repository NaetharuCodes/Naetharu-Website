---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Naetharu" description="Developer, writer, and tinkerer. Welcome to my corner of the internet.">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="hero-greeting">Hey there, I'm</p>
          <h1 class="hero-name">Naetharu</h1>
          <p class="hero-tagline">
            Developer, writer, and tinkerer. I build things, break things, and write about both.
            Particularly fond of low-level systems, graphics programming, and the occasional
            deep dive into game engine internals.
          </p>
          <div class="hero-actions">
            <a href="/tutorials" class="btn">Browse Tutorials</a>
            <a href="/blog" class="btn btn--outline">Read the Blog</a>
          </div>
        </div>
        <div class="hero-avatar">
          <div class="avatar-placeholder" aria-hidden="true">
            <span>N</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About snippet -->
  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>A bit about me</h2>
          <p>
            I've been writing code for over a decade, with a particular love for C++ and systems
            programming. When I'm not writing software, I'm usually reading about it — or
            writing tutorials to help others understand the things that took me a while to figure out.
          </p>
          <p>
            This site is my home on the internet: a place to share what I'm learning, document
            interesting problems I've solved, and occasionally muse about the state of the industry.
          </p>
          <a href="/contact" class="btn btn--outline" style="margin-top: 0.5rem;">Get in touch</a>
        </div>
        <div class="about-skills">
          <h3>What I work with</h3>
          <ul class="skill-list">
            <li><span class="tag">C++</span> Systems &amp; graphics programming</li>
            <li><span class="tag">TypeScript</span> Web frontends &amp; tooling</li>
            <li><span class="tag">Rust</span> Performance-critical utilities</li>
            <li><span class="tag">OpenGL / Vulkan</span> Rendering pipelines</li>
            <li><span class="tag">Python</span> Scripting &amp; data wrangling</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest tutorials -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Latest Tutorials</h2>
        <p>Step-by-step guides on the topics I care about most.</p>
      </div>
      <div class="card-grid">
        <a href="/tutorials/cpp-particle-systems" class="card card-link">
          <div class="card-tags">
            <span class="tag">C++</span>
            <span class="tag">Graphics</span>
          </div>
          <h3>Particle Systems in C++</h3>
          <p>Build a data-oriented, cache-friendly particle system from scratch using modern C++ techniques.</p>
          <span class="card-cta">Read tutorial &rarr;</span>
        </a>
        <div class="card card--coming-soon">
          <div class="card-tags">
            <span class="tag">C++</span>
            <span class="tag">Rendering</span>
          </div>
          <h3>OpenGL Basics: Your First Triangle</h3>
          <p>Getting started with OpenGL — setting up a context, shaders, and drawing your first geometry.</p>
          <span class="coming-soon-badge">Coming soon</span>
        </div>
        <div class="card card--coming-soon">
          <div class="card-tags">
            <span class="tag">Data Structures</span>
          </div>
          <h3>Writing a Lock-Free Queue</h3>
          <p>Explore atomic operations and memory ordering to build a thread-safe, lock-free queue in C++.</p>
          <span class="coming-soon-badge">Coming soon</span>
        </div>
      </div>
      <div class="section-footer">
        <a href="/tutorials" class="btn btn--outline">All tutorials &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Latest blog posts -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>From the Blog</h2>
        <p>Thoughts, notes, and the occasional rant.</p>
      </div>
      <div class="post-list">
        <a href="/blog/why-i-love-cpp" class="post-item">
          <div class="post-item-meta">
            <time>12 March 2025</time>
            <span class="tag">Opinion</span>
          </div>
          <h3>Why I Keep Coming Back to C++</h3>
          <p>Despite its notorious reputation, C++ continues to be the language I reach for when things need to be fast and correct.</p>
        </a>
        <a href="/blog/data-oriented-design" class="post-item">
          <div class="post-item-meta">
            <time>28 February 2025</time>
            <span class="tag">Design</span>
          </div>
          <h3>Data-Oriented Design: A Practical Primer</h3>
          <p>What it means to think in data rather than objects, and why your CPU will thank you for it.</p>
        </a>
      </div>
      <div class="section-footer">
        <a href="/blog" class="btn btn--outline">All posts &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
    max-width: 560px;
  }

  .hero-greeting {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-avatar { flex-shrink: 0; }

  .avatar-placeholder {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent), #4f3cc0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    font-weight: 800;
    color: rgba(255,255,255,0.9);
    border: 3px solid var(--color-border);
    user-select: none;
  }

  @media (max-width: 640px) {
    .hero-inner { flex-direction: column-reverse; align-items: flex-start; }
    .avatar-placeholder { width: 100px; height: 100px; font-size: 3rem; }
  }

  /* Sections */
  .section { padding: 4rem 0; }
  .section-footer { margin-top: 2.5rem; }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .about-text h2 { margin-bottom: 1rem; }
  .about-text p { color: var(--color-text-muted); }

  .about-skills h3 {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skill-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .about-grid { grid-template-columns: 1fr; }
  }

  /* Card grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link h3, .card h3 { margin: 0.75rem 0 0.5rem; font-size: 1.05rem; }
  .card-link p, .card p { font-size: 0.9rem; color: var(--color-text-muted); margin: 0; }
  .card--coming-soon { opacity: 0.6; }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-cta {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .coming-soon-badge {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Post list */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .post-item {
    display: block;
    padding: 1.5rem;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .post-item:not(:last-child) { border-bottom: 1px solid var(--color-border); }
  .post-item:hover { background: var(--color-surface-raised); }

  .post-item-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .post-item-meta time { color: var(--color-text-muted); font-size: 0.8rem; }
  .post-item h3 { margin-bottom: 0.35rem; font-size: 1rem; }
  .post-item p { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; }
</style>
