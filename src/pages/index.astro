---
import { getCollection } from 'astro:content';
import BaseLayout from "../layouts/BaseLayout.astro";

const tutorialCollections = await Promise.all([
  getCollection('microsoft-azure', ({ data }) => !data.draft),
  getCollection('devops',          ({ data }) => !data.draft),
  getCollection('scripts-and-automation', ({ data }) => !data.draft),
  getCollection('other',           ({ data }) => !data.draft),
]);

const latestTutorials = tutorialCollections
  .flat()
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title="Naetharu"
  description="Azure architect, cloud engineer, and DevOps practitioner. Tutorials, notes, and thoughts on building in the cloud."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="hero-greeting">Hey there, I'm</p>
          <h1 class="hero-name">James Bridge</h1>
          <p class="hero-tagline">
            Azure architect, cloud engineer, and DevOps practitioner. I design
            infrastructure, automate the tedious parts, and write about what I
            learn along the way.
          </p>
          <div class="hero-actions">
            <a href="/tutorials" class="btn">Browse Tutorials</a>
            <a href="/blog" class="btn btn--outline">Read the Blog</a>
          </div>
        </div>
        <div class="hero-avatar">
          <div class="avatar-placeholder" aria-hidden="true">
            <span>N</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About snippet -->
  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>A bit about me</h2>
          <p>
            I design and build Azure infrastructure for a living — cloud
            architecture, DevOps pipelines, and the automation that ties it all
            together.
          </p>
          <p>
            I'm also interested in the technical side of AI — I've done a fair
            amount of work with locally hosted models, custom training, and
            safety systems.
          </p>
          <p>
            This site is my home on the internet: a place to share what I'm
            learning, document interesting problems I've solved, and
            occasionally muse about the state of the industry.
          </p>
          <a
            href="/contact"
            class="btn btn--outline"
            style="margin-top: 0.5rem;">Get in touch</a
          >
        </div>
        <div class="about-skills">
          <h3>What I work with</h3>
          <ul class="skill-list">
            <li>
              <span class="tag">Azure</span> Cloud Engineering &amp; Architecture.
            </li>
            <li>
              <span class="tag">CI/CD</span> DevOps pipelines &amp; automation
            </li>
            <li>
              <span class="tag">PowerShell</span> Automation Scripting
            </li>
            <li>
              <span class="tag">Python</span> Scripting &amp; data wrangling
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest tutorials -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Latest Tutorials</h2>
        <p>Step-by-step guides on the topics I care about most.</p>
      </div>
      <div class="card-grid">
        {latestTutorials.map(t => (
          <a href={`/tutorials/${t.id}`} class="card card-link">
            <div class="card-tags">
              {t.data.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            <h3>{t.data.title}</h3>
            <p>{t.data.description}</p>
            <span class="card-cta">Read tutorial &rarr;</span>
          </a>
        ))}
      </div>
      <div class="section-footer">
        <a href="/tutorials" class="btn btn--outline">All tutorials &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Latest blog posts -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>From the Blog</h2>
        <p>Thoughts, notes, and the occasional rant.</p>
      </div>
      <div class="post-list">
        {latestPosts.map(post => (
          <a href={`/blog/${post.id}`} class="post-item">
            <div class="post-item-meta">
              <time>{post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
              {post.data.tags[0] && <span class="tag">{post.data.tags[0]}</span>}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
      <div class="section-footer">
        <a href="/blog" class="btn btn--outline">All posts &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
    max-width: 560px;
  }

  .hero-greeting {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-avatar {
    flex-shrink: 0;
  }

  .avatar-placeholder {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent), #4f3cc0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.9);
    border: 3px solid var(--color-border);
    user-select: none;
  }

  @media (max-width: 640px) {
    .hero-inner {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
    .avatar-placeholder {
      width: 100px;
      height: 100px;
      font-size: 3rem;
    }
  }

  /* Sections */
  .section {
    padding: 4rem 0;
  }
  .section-footer {
    margin-top: 2.5rem;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .about-text h2 {
    margin-bottom: 1rem;
  }
  .about-text p {
    color: var(--color-text-muted);
  }

  .about-skills h3 {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skill-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Card grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link h3,
  .card h3 {
    margin: 0.75rem 0 0.5rem;
    font-size: 1.05rem;
  }
  .card-link p,
  .card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .card--coming-soon {
    opacity: 0.6;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-cta {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .coming-soon-badge {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Post list */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .post-item {
    display: block;
    padding: 1.5rem;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .post-item:not(:last-child) {
    border-bottom: 1px solid var(--color-border);
  }
  .post-item:hover {
    background: var(--color-surface-raised);
  }

  .post-item-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .post-item-meta time {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .post-item h3 {
    margin-bottom: 0.35rem;
    font-size: 1rem;
  }
  .post-item p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
